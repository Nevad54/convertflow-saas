# ConvertFlow — Environment Variables
# Copy this file to .env for local development.
# Set all variables in Railway (or your VPS) dashboard for production.

# ─── App mode ────────────────────────────────────────────────────────────────
# "saas"  → auth, quota enforcement, Stripe payments (default; used by Docker/Railway)
# "local" → no auth, no quota, no payments (self-hosted / desktop use via start.bat)
APP_MODE=saas

# ─── Ollama (AI engine) ───────────────────────────────────────────────────────
# Local dev default: http://localhost:11434
# Docker / Railway: http://ollama:11434  (internal service name)
# Koyeb free tier: set OLLAMA_ENABLED=false (512 MB RAM can't host a vision model).
# Auto-engine OCR will fall back to tesseract / github / openai.
OLLAMA_ENABLED=true
OLLAMA_HOST=http://localhost:11434
OLLAMA_OCR_MODEL=gemma4:e4b

# ─── Auth (Phase 4) ──────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_me_generate_a_32_char_random_string

# ─── Stripe Payments (Phase 5) ───────────────────────────────────────────────
# From Stripe dashboard → Developers → API keys
STRIPE_SECRET_KEY=sk_live_...
# From Stripe dashboard → Developers → Webhooks → your endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_...
# From Stripe dashboard → Products → ConvertFlow Pro → Price ID
STRIPE_PRO_PRICE_ID=price_1ABC...

# ─── App URL ─────────────────────────────────────────────────────────────────
# Used for Stripe redirect URLs (checkout success / cancel).
# Auth cookies become Secure automatically when APP_URL starts with https://.
# Override with COOKIE_SECURE=true|false if you need explicit control.
# Local dev: http://localhost:8080
# Production: https://convertflow.io
APP_URL=http://localhost:8080

# ─── Persistence ─────────────────────────────────────────────────────────────
# Two options — pick ONE:
#
# Option A: SQLite (default; local dev, dedicated servers, or Koyeb with a volume)
#   Default DB lives at <repo>/cf.db. On ephemeral hosts (Koyeb free, Heroku)
#   point at a persistent volume mount, e.g. CF_DB_PATH=/data/cf.db and attach
#   a volume to that path. Without a volume SQLite resets on every redeploy.
# CF_DB_PATH=/data/cf.db
#
# Option B: Postgres (recommended for Koyeb free tier and any ephemeral-FS host)
#   Set DATABASE_URL and auth/models.py uses psycopg[binary] automatically.
#   Users and billing state survive redeploys without any volume setup.
#   Free managed Postgres options:
#     Neon:     https://neon.tech    (copy the "Pooled connection" URI)
#     Supabase: https://supabase.com (Project Settings → Database → Connection string, URI)
#   Both provide a free tier that fits this app.
# DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ─── Optional cloud OCR engines ──────────────────────────────────────────────
# GitHub Models (needs a PAT with models:read scope)
# GITHUB_TOKEN=ghp_...
# GITHUB_OCR_MODEL=openai/gpt-4.1-mini

# OpenAI
# OPENAI_API_KEY=sk-...
# OPENAI_OCR_MODEL=gpt-4.1-mini
